# ============================================================
# Variáveis de ambiente — copie este arquivo para .env e preencha
# ============================================================
#
# IMPORTANTE: o arquivo .env NUNCA deve ser commitado no Git.
# Ele já está listado no .gitignore.
#
# No Netlify, configure essas mesmas variáveis em:
# Site settings → Environment variables
# ============================================================

# URL do seu projeto Supabase
# Painel Supabase → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave pública (anon) do Supabase
# Painel Supabase → Settings → API → anon / public key
# OBS: esta chave É segura para uso no frontend desde que RLS esteja ativo.
SUPABASE_ANON_KEY=eyJhbGciOi...
